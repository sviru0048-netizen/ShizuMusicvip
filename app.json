{
  "name": "Shizu Music Bot",
  "description": "Shizu Music — Free Telegram VC Music Bot that runs easily on Render, Railway, Koyeb & Heroku.",
  "repository": "https://github.com/Badmunda05/ShizuMusic",
  "logo": "https://files.catbox.moe/9kwxtu.png",

  "keywords": [
    "telegram",
    "music",
    "bot",
    "vc",
    "python",
    "pyrogram",
    "shizumusic"
  ],

  "env": {
    "API_ID": {
      "description": "Your Telegram API_ID from https://my.telegram.org",
      "required": true
    },

    "API_HASH": {
      "description": "Your Telegram API_HASH from https://my.telegram.org",
      "required": true
    },

    "BOT_TOKEN": {
      "description": "Your Telegram Bot Token from @BotFather",
      "required": true
    },

    "STRING_SESSION": {
      "description": "Pyrogram String Session for Assistant Account",
      "required": true
    },

    "MONGO_DB_URL": {
      "description": "MongoDB Database URL",
      "required": true
    },

    "OWNER_ID": {
      "description": "Your Telegram User ID",
      "required": true
    },

    "LOGGER_ID": {
      "description": "Logger Group/Channel ID",
      "required": false
    },

    "BOT_NAME": {
      "description": "Your Bot Name",
      "required": false
    },

    "BOT_LINK": {
      "description": "Your Bot Username Link",
      "required": false
    },

    "UPDATES_CHANNEL": {
      "description": "Updates Channel Link",
      "required": false
    },

    "SUPPORT_GROUP": {
      "description": "Support Group Link",
      "required": false
    },

    "START_ANIMATION": {
      "description": "Start Animation / Video URL",
      "required": false
    },

    "PING_IMG_URL": {
      "description": "Ping Command Image URL",
      "required": false
    },

    "SESSION_NAME": {
      "description": "Pyrogram Session Name",
      "required": false,
      "value": "ShizuMusic"
    },

    "PORT": {
      "description": "Port Number",
      "required": false,
      "value": "10000"
    },

    "MAX_DURATION_SECONDS": {
      "description": "Maximum Song Duration Limit",
      "required": false,
      "value": "1800"
    },

    "QUEUE_LIMIT": {
      "description": "Maximum Queue Limit",
      "required": false,
      "value": "20"
    },

    "COOLDOWN": {
      "description": "Command Cooldown Time",
      "required": false,
      "value": "10"
    }
  },
      "buildpacks": [
          {
              "url": "heroku/python"
          },
          {
              "url": "https://github.com/jonathanong/heroku-buildpack-ffmpeg-latest.git"
          }
      ],
      "formation": {
          "worker": {
              "quantity": 1,
              "size": "basic"
          }
      }
  }
  
