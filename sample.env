# ════════════════════════════════════════════════════
#            ShizuMusic — Environment Variables
# ════════════════════════════════════════════════════

# ── REQUIRED ────────────────────────────────────────

# Telegram API Credentials
# Get from: https://my.telegram.org
API_ID=
API_HASH=

# Telegram Bot Token
# Get from: @BotFather
BOT_TOKEN=

# Pyrogram String Session
# Generate from your assistant account
STRING_SESSION=

# MongoDB Database URL
# Get free cluster from: https://cloud.mongodb.com
MONGO_DB_URL=

# Your Telegram User ID
OWNER_ID=

# Logger Group / Channel ID
LOGGER_ID=

# ── BOT SETTINGS ────────────────────────────────────

BOT_NAME=
BOT_LINK=

UPDATES_CHANNEL=
SUPPORT_GROUP=

# ── MEDIA ───────────────────────────────────────────

START_ANIMATION=https://telegra.ph/file/1a3c152717eb9d2e94dc2.mp4
PING_IMG_URL=https://files.catbox.moe/ddzvc0.jpg

# ── SYSTEM ──────────────────────────────────────────

SESSION_NAME=ShizuMusic
PORT=10000

# ── LIMITS ──────────────────────────────────────────

MAX_DURATION_SECONDS=1800
QUEUE_LIMIT=20
COOLDOWN=10
