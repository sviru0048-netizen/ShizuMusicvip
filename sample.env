# ════════════════════════════════════════════════════
#           ShizuMusic — Environment Variables
#           Copy this file to .env and fill in values
# ════════════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────────────
# Get from https://my.telegram.org
API_ID=
API_HASH=

# Get from @BotFather on Telegram
BOT_TOKEN=

# Pyrogram string session for your assistant account
# Generate: python3 -c "from pyrogram import Client; Client('s', api_id=ID, api_hash='HASH').run()"
STRING_SESSION=

# MongoDB URI — get free cluster at https://cloud.mongodb.com
# Format: mongodb+srv://username:password@cluster.mongodb.net/ShizuMusic
MONGO_DB_URL=

# Your own Telegram user ID (integer)
OWNER_ID=

# ── OPTIONAL ──────────────────────────────────────────
BOT_NAME=Shizu Music
BOT_LINK=https://t.me/ShizuMusicBot
UPDATES_CHANNEL=https://t.me/PBX_UPDATE
SUPPORT_GROUP=https://t.me/PBXCHATS

# Chat ID where the bot sends startup/error logs (leave blank to disable)
LOGGER_ID=

START_ANIMATION=https://telegra.ph/file/1a3c152717eb9d2e94dc2.mp4
PING_IMG_URL=https://files.catbox.moe/ddzvc0.jpg
SESSION_NAME=ShizuMusic
PORT=10000

# ── LIMITS ────────────────────────────────────────────
MAX_DURATION_SECONDS=1800
QUEUE_LIMIT=20
COOLDOWN=10
